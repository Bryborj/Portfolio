---
import { basics } from "@cv"
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string
}

const { title } = Astro.props

const { image, summary } = basics
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={summary} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="image" href={image} />
  </head>
  <body>
    <slot />
    <SpeedInsights/>
  </body>
</html>

<style is:global>
  :root {
    --bg-color: #0d1117;
    --text-primary: #e6edf3;
    --text-secondary: #8b949e;
    --accent: #58a6ff;
    --accent-hover: #3182ce;
    --border-color: #30363d;
    --card-bg: #161b22;
    --card-hover: #21262d;
    --badge-bg: #1f2428;
    --badge-text: #58a6ff;
  }

  @media print {
    :root {
      --bg-color: #ffffff;
      --text-primary: #111111;
      --text-secondary: #444444;
      --accent: #000000;
      --accent-hover: #000000;
      --border-color: #eeeeee;
      --card-bg: #ffffff;
      --card-hover: #ffffff;
      --badge-bg: #f3f4f6;
      --badge-text: #111111;
    }
  }

  html {
    font-family:
      "Inter",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
    background: var(--bg-color);
    color: var(--text-primary);
    letter-spacing: -0.025rem;
    transition: background 0.3s ease;
  }

  body,
  figure {
    margin: 0;
    padding: 0;
  }

  a {
    text-decoration: none;
    color: var(--accent);
    transition: color 0.3s ease;
  }

  a:hover {
    color: var(--accent-hover);
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    color: var(--text-primary);
    font-family: inherit;
  }

  p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    text-wrap: pretty;
  }

  @media print {
    .no-print {
      display: none !important;
    }
    
    body {
      background: #fff !important;
      color: #000 !important;
      font-size: 12pt;
    }
    
    @page {
      margin: 1cm;
    }
  }

  .print {
    display: none !important;
  }

  @media print {
    .print {
      display: block !important;
    }
  }
</style>
