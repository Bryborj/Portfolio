---
import { basics } from "@cv";

interface Props {
  title: string;
}

const { title } = Astro.props;

const { image, summary } = basics;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={summary} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="image" href={image} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg-color: #000000;
    --text-primary: #f8fafc;
    --text-secondary: #a1a1aa;

    /* Favorite colors */
    --accent-blue: #3b82f6;
    --accent-red: #ef4444;
    --accent-purple: #8b5cf6;

    --accent: var(--accent-purple);
    --accent-hover: var(--accent-blue);

    --gradient-primary: linear-gradient(
      135deg,
      var(--accent-blue),
      var(--accent-purple),
      var(--accent-red)
    );
    --gradient-glow: radial-gradient(
      circle at center,
      rgba(139, 92, 246, 0.15) 0%,
      transparent 70%
    );

    --border-color: transparent;
    --card-bg: #09090b;
    --card-hover: #18181b;
    --badge-bg: #18181b;
    --badge-text: #e4e4e7;
  }

  @media print {
    :root {
      --bg-color: #ffffff;
      --text-primary: #111111;
      --text-secondary: #444444;
      --accent: #000000;
      --accent-hover: #000000;
      --border-color: #eeeeee;
      --card-bg: #ffffff;
      --card-hover: #ffffff;
      --badge-bg: #f3f4f6;
      --badge-text: #111111;
      --gradient-primary: none;
      --gradient-glow: none;
    }
  }

  .gradient-text {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  @media print {
    .gradient-text {
      background: none !important;
      -webkit-text-fill-color: #000 !important;
      color: #000 !important;
    }
  }

  html {
    font-family:
      "Inter",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
    background: var(--bg-color);
    color: var(--text-primary);
    letter-spacing: -0.025rem;
    transition: background 0.3s ease;
    scroll-behavior: smooth;
  }

  body,
  figure {
    margin: 0;
    padding: 0;
  }

  a {
    text-decoration: none;
    color: var(--accent);
    transition: color 0.3s ease;
  }

  a:hover {
    color: var(--accent-hover);
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    color: var(--text-primary);
    font-family: inherit;
  }

  p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    text-wrap: pretty;
  }

  @media print {
    .no-print {
      display: none !important;
    }

    body {
      background: #fff !important;
      color: #000 !important;
      font-size: 12pt;
    }

    @page {
      margin: 1cm;
    }
  }

  .print {
    display: none !important;
  }

  @media print {
    .print {
      display: block !important;
    }
  }
</style>
