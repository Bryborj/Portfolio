---
import Section from "../Section.astro"

import { work } from "@cv"
---

<Section title="Experiencia laboral">
  <ul>
    {
      work.map(
        ({ name, startDate, endDate, position, summary, highlights, propietary, url }) => {
          const startYear = new Date(startDate).getFullYear()
          const endYear =
            endDate != "" ? new Date(endDate).getFullYear() : "Actual"
          const years = `${startYear} - ${endYear}`
          const Propietary = propietary ? " (Propietario)" : false
          const highlightList = highlights
            ? highlights.map((highlight) => <li>• {highlight}</li>)
            : null

          return (
            <li>
              <article>
                <header>
                  <div>
                    <a
                      href={url}
                      title={`Ver la empresa ${name}`}
                      target="_blank"
                      rel="noopener noreferrer">
                    <h3>{name}{Propietary && <span class="prop">{Propietary}</span>}</h3>
                    </a>

                    <h4>{position}</h4>
                  </div>

                  <time>{years}</time>
                </header>

                <footer>
                  <p>{summary}</p>
                  {highlightList && <div class="highlights">{highlightList}</div>}
                </footer>
              </article>
            </li>
          )
        }
      )
    }
  </ul>
</Section>

<style>
  .prop {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-left: 8px;
    font-style: italic;
  }
  .highlights {
    margin-top: 8px;
    margin-left: 1rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 600;
    color: var(--text-primary);
    display: flex;
    align-items: center;
  }

  article h4 {
    color: var(--text-secondary);
    font-weight: 400;
    margin-top: 4px;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 8px;
  }

  time {
    color: var(--text-secondary);
    font-size: 0.85rem;
    background: var(--card-bg);
    padding: 2px 8px;
    border-radius: 4px;
    border: 1px solid var(--border-color);
  }

  a:hover h3 {
    color: var(--accent);
  }

  @media print {
    time {
      border: none;
      background: transparent;
      padding: 0;
    }
  }
</style>
