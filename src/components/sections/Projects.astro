---
import Section from "../Section.astro"

import { projects } from "@cv"
---

<Section title="Proyectos">
  <ul>
    {
      projects.map(({ url, description, highlights, name, isActive }) => {
        const thisurl = isActive ? url : "/magnament";
        return (
          <li>
            <article>
              <header>
                <h3>
                  <a href={thisurl}
                  title={`Ver el proyecto ${name}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  >
                    {name}
                  </a>
                  {isActive && <span>•</span>}
                </h3>
                <p>{description}</p>
              </header>
              <footer>
                {highlights.map((highlight) => {
                  return <span>{highlight}</span>
                })}
              </footer>
            </article>
          </li>
        )
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-inline: -16px;
  }

  article {
    border-radius: 12px;
    border: 1px solid var(--border-color);
    background: var(--card-bg);
    gap: 16px;
    display: flex;
    flex-direction: column;
    padding: 20px;
    height: 100%;
    transition: all 0.3s ease;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  article:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 0 8px 24px rgba(88, 166, 255, 0.1);
    background: var(--card-hover);
  }

  article header {
    flex: 1;
  }

  article h3 {
    margin-bottom: 8px;
    font-weight: 600;
  }

  article a {
    color: var(--text-primary);
  }

  article a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  article p {
    font-size: 0.85rem;
    line-height: 1.4rem;
    margin-bottom: 4px;
    color: var(--text-secondary);
  }

  article h3 span {
    color: #3fb950;
    margin-left: 6px;
    animation: pulse 2s infinite ease-in-out;
  }

  @keyframes pulse {
    0% { opacity: 0.5; }
    50% { opacity: 1; }
    100% { opacity: 0.5; }
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 0.7rem;
    margin-top: 12px;
  }

  footer span {
    border-radius: 6px;
    background: var(--badge-bg);
    color: var(--badge-text);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--border-color);
  }

  @media print {
    article {
      border: 1px solid #ddd;
      box-shadow: none;
      page-break-inside: avoid;
    }
    article:hover {
      transform: none;
      box-shadow: none;
    }
  }
</style>
