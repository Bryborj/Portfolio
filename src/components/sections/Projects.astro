---
import Section from "../Section.astro";

import { projects } from "@cv";
import { getThumURL } from "thum.io";
---

<Section title="Proyectos" id="proyectos">
  <ul>
    {
      projects.map(({ url, description, highlights, name, isActive }) => {
        const thisurl = isActive ? url : "/magnament";
        const previewUrl = isActive
          ? getThumURL({ url, width: 600, crop: 800, protocol: "https" })
          : "/preview-placeholder.jpg";
        return (
          <li>
            <article>
              <a
                href={thisurl}
                target="_blank"
                rel="noopener noreferrer"
                class="preview-link"
              >
                <div class="image-container">
                  {isActive ? (
                    <img
                      src={previewUrl}
                      alt={`Vista previa de ${name}`}
                      loading="lazy"
                    />
                  ) : (
                    <div class="placeholder-preview gradient-text">
                      Sin Vista Previa
                    </div>
                  )}
                </div>
              </a>
              <header>
                <h3>
                  <a
                    href={thisurl}
                    title={`Ver el proyecto ${name}`}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {name}
                  </a>
                  {isActive && <span>•</span>}
                </h3>
                <p>{description}</p>
              </header>
              <footer>
                {highlights.map((highlight) => {
                  return <span>{highlight}</span>;
                })}
              </footer>
            </article>
          </li>
        );
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin-inline: -16px;
  }

  article {
    border-radius: 16px;
    border: 1px solid var(--border-color);
    background: var(--card-bg);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    overflow: hidden;
  }

  article:hover {
    transform: translateY(-8px);
    border-color: var(--accent);
    box-shadow: 0 12px 30px rgba(139, 92, 246, 0.15);
  }

  .preview-link {
    display: block;
    width: 100%;
    overflow: hidden;
  }

  .image-container {
    width: 100%;
    height: 180px;
    background: #000;
    position: relative;
    border-bottom: 1px solid var(--border-color);
  }

  .image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  article:hover .image-container img {
    transform: scale(1.08);
  }

  .placeholder-preview {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    font-weight: 700;
    background: #111;
  }

  article header {
    flex: 1;
    padding: 20px 20px 0 20px;
  }

  article h3 {
    margin-bottom: 8px;
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
  }

  article a {
    color: var(--text-primary);
  }

  article a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  article p {
    font-size: 0.9rem;
    line-height: 1.5rem;
    margin-bottom: 0;
    color: var(--text-secondary);
  }

  article h3 span {
    color: #3fb950;
    margin-left: 6px;
    animation: pulse 2.5s infinite ease-in-out;
  }

  @keyframes pulse {
    0% {
      opacity: 0.4;
    }
    50% {
      opacity: 1;
    }
    100% {
      opacity: 0.4;
    }
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 0.75rem;
    padding: 20px;
    margin-top: auto;
  }

  footer span {
    border-radius: 8px;
    background: var(--badge-bg);
    color: var(--badge-text);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.4rem 0.8rem;
    border: 1px solid var(--border-color);
  }

  @media print {
    article {
      border: 1px solid #ddd;
      box-shadow: none;
      page-break-inside: avoid;
    }
    article:hover {
      transform: none;
      box-shadow: none;
    }
    .preview-link {
      display: none;
    }
  }
</style>
